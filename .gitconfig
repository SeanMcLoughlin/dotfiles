[user]
	name = Sean McLoughlin
	email = smcloughlin@tenstorrent.com
[init]
    defaultBranch = main
[pull]
    rebase = true
[diff]
    external = difft
    # Set difftastic as the default difftool, so we don't need to specify
    # `-t difftastic` every time.
    tool = difftastic
[difftool]
    # Run the difftool immediately, don't ask 'are you sure' each time.
    prompt = false
[pager]
    # Use a pager if the difftool output is larger than one screenful,
    # consistent with the behaviour of `git diff`.
    difftool = true
[alias]
    # Various uninteresting shortcuts
    c = commit
    p = pull
    a = add
    s = status
    st = status
    l = log
    wt = worktree
    rb = rebase

    hs = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr)%Creset' --abbrev-commit --date=relative
    myhs = "!git log --author=\"$(git config --get user.name)\""
    fstatus = status --porcelain --branch --untracked-files=no

    # quickly amend the most recent commit with the contents of the index.
    cane = commit --amend --no-edit
    co = checkout

    # Get the latest tag -- the "release"
    rel = describe --tags --abbrev=0

    # List all git aliases in .gitconfig
    lsalias = config --get-regexp ^alias

    # List all tags
    tags = for-each-ref --sort=creatordate --format '%(refname) %(creatordate)' refs/tags

    # Commits made via `--fixup` or `--squash` will be placed in the right locations automatically.
    rebi = rebase --interactive --autosquash

    # Clears out any branches that have been deleted on your remotes
    fetchp = fetch --prune --all

    # Completely synchronize and update all submodules
    subu = "!f() { git submodule sync --recursive && git submodule update --init --recursive; }; f"

    # Delete local branches that have already been merged into main, aside from "main" and "develop" branches.
    rm-stale-branches = "!git branch --merged origin/main | grep -vE \"^\\s*(\\*|main|develop)\" | xargs -n 1 git branch -d"

    # Delete local and remote branches that have already been merged.
    rm-branch = "!f() { git branch -d \"$1\" && git push origin --delete \"$1\"; }; f"

    # Forcibly delete local and remote branches, even if they have not yet been merged. This requires a confirmation prompt to avoid accidental data loss!
    rm-rf-branch = "!f() { read -p \"Delete branch '$1' locally and remotely? THIS IS AN IRREVERSIBLE ACTION!(y/n) \" -n 1 -r && echo && [[ $REPLY =~ ^[Yy]$ ]] && git branch -D \"$1\" && git push origin --delete \"$1\"; }; f"

    # https://piechowski.io/post/git-commands-before-reading-code/
	who-built-this = shortlog -sn --no-merges
	where-do-bugs-cluster = !git log -i -E --grep='fix|bug|broken' --name-only --format='' | sort | uniq -c | sort -nr | head -20
	is-project-accelerating-or-dying = !git log --format='%ad' --date=format:'%Y-%m' | sort | uniq -c
	firefight-frequency = !git log --oneline --since='1 year ago' | grep -iE 'revert|hotfix|emergency|rollback'
	

[push]
	autoSetupRemote = true
[credential]
	helper = osxkeychain
