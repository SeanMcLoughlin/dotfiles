### Display
theme = dark:"Catppuccin Frappe", light:"Catppuccin Latte"
font-family = "iMWritingMono Nerd Font Mono"
font-size = 14
adjust-cell-width = "-10%"
adjust-cell-height = "10%"
copy-on-select = clipboard
shell-integration-features = ssh-terminfo, ssh-env
window-save-state = always
macos-option-as-alt = true

### Unbind default keybindings that overlap with tmux-style bindings
keybind = super+t=unbind
keybind = super+w=unbind
keybind = super+alt+w=unbind
keybind = super+d=unbind
keybind = super+shift+d=unbind
keybind = super+shift+[=unbind
keybind = super+shift+]=unbind
keybind = super+[=unbind
keybind = super+]=unbind
keybind = super+alt+arrow_up=unbind
keybind = super+alt+arrow_down=unbind
keybind = super+alt+arrow_left=unbind
keybind = super+alt+arrow_right=unbind
keybind = super+ctrl+arrow_up=unbind
keybind = super+ctrl+arrow_down=unbind
keybind = super+ctrl+arrow_left=unbind
keybind = super+ctrl+arrow_right=unbind
keybind = super+shift+,=unbind
keybind = ctrl+shift+tab=unbind
keybind = ctrl+tab=unbind
keybind = super+1=unbind
keybind = super+2=unbind
keybind = super+3=unbind
keybind = super+4=unbind
keybind = super+5=unbind
keybind = super+6=unbind
keybind = super+7=unbind
keybind = super+8=unbind

### tmux-style keybindings (ctrl+b prefix)
#
# Mirrors ~/.tmux.conf rebindings:
#   prefix + c       → new tab
#   prefix + -       → split down (horizontal in tmux terms)
#   prefix + \       → split right (vertical in tmux terms)
#   prefix + x       → close pane/tab
#   prefix + n       → next tab
#   prefix + p       → previous tab
#   prefix + 1-9     → go to tab N
#   prefix + z       → toggle split zoom
#   prefix + h/j/k/l → navigate splits
#   prefix + H/J/K/L → resize splits
#   Ctrl+Shift+Left/Right → move tab left/right (matches tmux swap-window)

# Splits
keybind = ctrl+b>minus=new_split:down
keybind = ctrl+b>shift+backslash=new_split:right

# Tabs
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>n=next_tab
keybind = ctrl+b>p=previous_tab
keybind = ctrl+b>one=goto_tab:1
keybind = ctrl+b>two=goto_tab:2
keybind = ctrl+b>three=goto_tab:3
keybind = ctrl+b>four=goto_tab:4
keybind = ctrl+b>five=goto_tab:5
keybind = ctrl+b>six=goto_tab:6
keybind = ctrl+b>seven=goto_tab:7
keybind = ctrl+b>eight=goto_tab:8
keybind = ctrl+b>nine=goto_tab:9

# Rename tab (like tmux prefix + ,)
keybind = ctrl+b>comma=prompt_tab_title

# Rename terminal title (like tmux prefix + $ for rename session)
keybind = ctrl+b>shift+four=prompt_surface_title

# Move tabs (matches tmux Ctrl+Shift+Left/Right for swap-window)
keybind = ctrl+shift+left=move_tab:-1
keybind = ctrl+shift+right=move_tab:1

# Close pane/surface
keybind = ctrl+b>x=close_surface

# Split navigation (like tmux prefix + arrow keys)
keybind = ctrl+b>arrow_left=goto_split:left
keybind = ctrl+b>arrow_down=goto_split:bottom
keybind = ctrl+b>arrow_up=goto_split:top
keybind = ctrl+b>arrow_right=goto_split:right

# Zoom/maximize current split (like tmux prefix + z)
keybind = ctrl+b>z=toggle_split_zoom

# Reload config (like tmux prefix + r)
keybind = ctrl+b>r=reload_config

# Equalize splits
keybind = ctrl+b>equal=equalize_splits
