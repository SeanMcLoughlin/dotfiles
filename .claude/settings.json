      "Bash(llvm-:*)",
      "Bash(tart:*)",
      "Bash(ssh:*)",
      "Bash(sshpass:*)",
      "Bash(glab auth status:*)",
      "Bash(glab check-update:*)",
      "Bash(glab ci list:*)",
      "Bash(glab ci view:*)",
      "Bash(glab ci get:*)",
      "Bash(glab ci artifact:*)",
      "Bash(glab config get:*)",
      "Bash(glab config list:*)",
      "Bash(glab deploy-key list:*)",
      "Bash(glab environment list:*)",
      "Bash(glab environment view:*)",
      "Bash(glab event list:*)",
      "Bash(glab incident list:*)",
      "Bash(glab incident view:*)",
      "Bash(glab issue list:*)",
      "Bash(glab issue view:*)",
      "Bash(glab issue note list:*)",
      "Bash(glab iteration list:*)",
      "Bash(glab job list:*)",
      "Bash(glab job log:*)",
      "Bash(glab job get:*)",
      "Bash(glab label list:*)",
      "Bash(glab member list:*)",
      "Bash(glab milestone list:*)",
      "Bash(glab mr list:*)",
      "Bash(glab mr view:*)",
      "Bash(glab mr diff:*)",
      "Bash(glab mr checks:*)",
      "Bash(glab mr note list:*)",
      "Bash(glab pipeline list:*)",
      "Bash(glab pipeline view:*)",
      "Bash(glab project list:*)",
      "Bash(glab project view:*)",
      "Bash(glab registry list:*)",
      "Bash(glab release list:*)",
      "Bash(glab release view:*)",
      "Bash(glab release download:*)",
      "Bash(glab repo view:*)",
      "Bash(glab runner list:*)",
      "Bash(glab runner view:*)",
      "Bash(glab schedule list:*)",
      "Bash(glab search:*)",
      "Bash(glab snippet list:*)",
      "Bash(glab snippet view:*)",
      "Bash(glab ssh-key list:*)",
      "Bash(glab token list:*)",
      "Bash(glab topic list:*)",
      "Bash(glab user status:*)",
      "Bash(glab variable list:*)",
      "Bash(glab version:*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true,
    "swift-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "worktrunk": {
      "source": {
        "source": "github",
        "repo": "max-sixty/worktrunk"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "~/repos",
        "~/.dotfiles"
      ],
      "allowRead": [
        "~/repos",
        "~/Documents/specs",
        "~/Documents/ai-context",
        "~/.dotfiles",
        "~/.claude"
      ]
    }
  },
  "showClearContextOnPlanAccept": true,
  "skipAutoPermissionPrompt": true,
  "effortLevel": "medium"
}
