      "Bash(git describe:*)",
      "Bash(git tag:*)",
      "Bash(git shortlog:*)",
      "Bash(git stash list:*)",
      "Bash(chmod:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(env:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
