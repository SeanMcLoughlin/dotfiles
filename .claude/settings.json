{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gitlab.com)",
      "WebFetch(domain:crates.io)",
      "WebFetch(domain:docs.rs)",
      "WebFetch(domain:lib.rs)",
      "WebSearch",
      "Bash(brew list:*)",
      "Bash(echo:*)",
      "Bash(cargo:*)",
      "Bash(log:*)",
      "Bash(find:*)",
      "Bash(dot:*)",
      "Bash(mdformat:*)",
      "Bash(prettier:*)",
      "Bash(black:*)",
      "Bash(pylint:*)",
      "Bash(pytest:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(export:*)",
      "Bash(which:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(verilator:*)",
      "Bash(verible-:*)",
      "Bash(grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git rev-list:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git remote:*)",
      "Bash(git config:*)",
      "Bash(git describe:*)",
      "Bash(git tag:*)",
      "Bash(git shortlog:*)",
      "Bash(git stash list:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(env:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(uname:*)",
      "Bash(whoami:*)",
      "Bash(id:*)",
      "Bash(man:*)",
      "Bash(type:*)",
      "Bash(realpath:*)",
      "Bash(readlink:*)",
      "Bash(basename:*)",
      "Bash(dirname:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(tr:*)",
      "Bash(awk:*)",
      "Bash(sed:*)",
      "Bash(xargs:*)",
      "Bash(jq:*)",
      "Bash(date:*)"
    ]
  },
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true
  }
}
